# Copy this file to .env and fill in your values
# Railway will auto-provide DATABASE_URL when you add PostgreSQL

DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
PORT=3001

# Admin login credentials (change before deploying!)
ADMIN_EMAIL=admin@transport.com
ADMIN_PASSWORD=Transport@2024
